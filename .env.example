# Copy to .env and fill in. docker-compose reads .env automatically.

# Postgres credentials. Generate a real password with:
#   openssl rand -base64 24 | tr -d '/+='
# Changing POSTGRES_PASSWORD after the db volume already exists does NOT change it in
# the running database — that has to be done for real with ALTER ROLE first, or the
# app will fail to authenticate.
POSTGRES_USER=mailapp
POSTGRES_PASSWORD=
POSTGRES_DB=mailapp

# Authentik OIDC application — create an OAuth2/OpenID provider + application
# in Authentik, redirect URI: http://<your-lan-ip>:8080/auth/callback
OIDC_ISSUER=https://authentik.example.com/application/o/<slug>/
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=http://<your-lan-ip>:8080/auth/callback

# Encrypts stored IMAP account passwords at rest. Generate with:
#   openssl rand -base64 32
ENCRYPTION_KEY=

# Web Push (browser notifications). Generate once with a small Go script using
# webpush-go's GenerateVAPIDKeys() — reused for every subscription, do not regenerate,
# or existing subscribers' push will silently start failing.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Optional — how long a login session lasts. Defaults to 30 days in the app if unset.
# SESSION_TTL_DAYS=30
