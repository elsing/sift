# Copy to .env and fill in. docker-compose reads .env automatically.

# Postgres credentials. Generate a real password with:
#   openssl rand -base64 24 | tr -d '/+='
# Changing POSTGRES_PASSWORD after the db volume already exists does NOT change it in
# the running database — that has to be done for real with ALTER ROLE first, or the
# app will fail to authenticate.
POSTGRES_USER=mailapp
POSTGRES_PASSWORD=
POSTGRES_DB=mailapp

# Authentik OIDC application — create an OAuth2/OpenID provider + application
# in Authentik, redirect URI: http://<your-lan-ip>:8080/auth/callback
OIDC_ISSUER=https://authentik.example.com/application/o/<slug>/
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=http://<your-lan-ip>:8080/auth/callback

# Google OAuth client — lets you connect a Gmail account via "Sign in with Google"
# instead of typing a password/app-password. Optional: account linking falls back to
# the regular manual IMAP form if these are left blank.
#   1. https://console.cloud.google.com/apis/credentials -> Create Credentials ->
#      OAuth client ID -> Web application.
#   2. Authorized redirect URI: http://<your-lan-ip>:8080/api/accounts/oauth/google/callback
#   3. OAuth consent screen: add your own Google account as a test user if the app is
#      in "Testing" status (the default) — otherwise Google refuses to grant it.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://<your-lan-ip>:8080/api/accounts/oauth/google/callback

# Encrypts stored IMAP account passwords (and Google OAuth tokens) at rest. Generate with:
#   openssl rand -base64 32
ENCRYPTION_KEY=

# Web Push (browser notifications). Generate once with a small Go script using
# webpush-go's GenerateVAPIDKeys() — reused for every subscription, do not regenerate,
# or existing subscribers' push will silently start failing.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Optional — how long a login session lasts. Defaults to 30 days in the app if unset.
# SESSION_TTL_DAYS=30

# Optional — how often (hours, can be fractional e.g. 0.1) the server rechecks each
# account's folder list directly over IMAP for changes made outside this app (another
# mail client, the actual webmail). This app's own create/rename/delete already push
# an update immediately and don't need this. Defaults to 2 hours if unset.
# FOLDER_CHECK_INTERVAL_HOURS=2
