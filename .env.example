# Copy to .env and fill in. docker-compose reads .env automatically.

# Authentik OIDC application — create an OAuth2/OpenID provider + application
# in Authentik, redirect URI: http://<your-lan-ip>:8080/auth/callback
OIDC_ISSUER=https://authentik.example.com/application/o/<slug>/
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=http://<your-lan-ip>:8080/auth/callback

# Encrypts stored IMAP account passwords at rest. Generate with:
#   openssl rand -base64 32
ENCRYPTION_KEY=
